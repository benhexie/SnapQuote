<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - <%= project_name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .print-exact { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        @media print {
            body { background-color: white; padding: 0; }
            .print-hide { display: none; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '<%= locals.theme_color || "#2563eb" %>',
                        brandLight: '<%= locals.theme_color_light || "#eff6ff" %>'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-100 p-8 flex justify-center print:p-0">
    <div class="bg-white w-full max-w-4xl shadow-2xl rounded-xl overflow-hidden print:shadow-none print:rounded-none">
        
        <!-- Header -->
        <div class="p-12 flex justify-between items-start">
            <div class="space-y-4">
                <% if (locals.company_logo) { %>
                    <img src="<%= company_logo %>" alt="Company Logo" class="h-20 object-contain">
                <% } else { %>
                    <h2 class="text-4xl font-black text-gray-900 tracking-tight"><%= locals.company_name || 'Your Company Name' %></h2>
                <% } %>
                <div class="text-gray-500 text-sm leading-relaxed">
                    <p><%= locals.company_address || '123 Business Road, Suite 100\nCity, State 12345' %></p>
                    <p><%= locals.company_email || 'hello@yourcompany.com' %></p>
                    <p><%= locals.company_phone || '(555) 123-4567' %></p>
                </div>
            </div>
            <div class="text-right">
                <h1 class="text-5xl font-black text-brand tracking-widest uppercase mb-4">INVOICE</h1>
                <div class="text-gray-600 text-sm space-y-2">
                    <p><span class="font-bold text-gray-800 uppercase tracking-wider text-xs mr-2">Invoice #</span> <%= locals.invoice_number || 'INV-0001' %></p>
                </div>
            </div>
        </div>

        <!-- Billing Info -->
        <div class="px-12 py-8 bg-gray-50 print:bg-transparent border-y border-gray-100 flex justify-between items-start">
            <div>
                <h3 class="text-xs font-black text-brand uppercase tracking-widest mb-3">Billed To</h3>
                <p class="font-bold text-gray-900 text-xl"><%= locals.client_name || 'Client Name' %></p>
                <p class="text-gray-500 text-sm mt-2 max-w-xs leading-relaxed whitespace-pre-line">
                    <%= locals.client_address || 'Client Address\nCity, State Zip' %>
                </p>
                <% if (locals.client_email) { %>
                    <p class="text-gray-500 text-sm mt-1"><%= client_email %></p>
                <% } %>
            </div>
            <div class="text-right">
                <h3 class="text-xs font-black text-brand uppercase tracking-widest mb-3">Project</h3>
                <p class="font-bold text-gray-900 text-xl max-w-sm"><%= project_name %></p>
            </div>
        </div>

        <!-- Items Table -->
        <div class="p-12">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b-2 border-brand text-gray-800">
                        <th class="py-4 px-2 font-bold uppercase text-xs tracking-wider w-1/2">Description</th>
                        <th class="py-4 px-2 font-bold uppercase text-xs tracking-wider text-center">Qty</th>
                        <th class="py-4 px-2 font-bold uppercase text-xs tracking-wider text-right">Rate</th>
                        <th class="py-4 px-2 font-bold uppercase text-xs tracking-wider text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 text-sm">
                    <% line_items.forEach(function(item) { %>
                    <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="py-5 px-2">
                            <p class="font-medium text-gray-900 text-base"><%= item.description %></p>
                        </td>
                        <td class="py-5 px-2 text-center font-medium"><%= item.quantity %></td>
                        <td class="py-5 px-2 text-right"><%= locals.currency || '$' %><%= item.unit_price.toFixed(2) %></td>
                        <td class="py-5 px-2 text-right font-bold text-gray-900"><%= locals.currency || '$' %><%= (item.quantity * item.unit_price).toFixed(2) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <!-- Summary -->
        <div class="px-12 py-8 flex justify-between bg-brandLight print:bg-transparent print:border-t print:border-gray-200">
            <% if (locals.terms) { %>
            <div class="w-full max-w-md pr-8">
                <h3 class="font-bold text-gray-800 uppercase tracking-wider text-sm mb-2">Terms & Conditions</h3>
                <p class="text-sm text-gray-600 whitespace-pre-line"><%= locals.terms %></p>
            </div>
            <% } %>
            <div class="w-full max-w-sm space-y-4 <% if (!locals.terms) { %>ml-auto<% } %>">
                <div class="flex justify-between text-gray-600 text-base">
                    <span>Subtotal</span>
                    <span class="font-medium"><%= locals.currency || '$' %><%= subtotal.toFixed(2) %></span>
                </div>
                <% if (locals.discount) { %>
                <div class="flex justify-between text-gray-600 text-base">
                    <span>Discount</span>
                    <span class="font-medium text-red-500">-<%= locals.currency || '$' %><%= Number(discount).toFixed(2) %></span>
                </div>
                <% } %>
                <div class="flex justify-between text-gray-600 text-base">
                    <span>Taxes (Estimated)</span>
                    <span class="font-medium"><%= locals.currency || '$' %><%= taxes.toFixed(2) %></span>
                </div>
                <div class="flex justify-between text-2xl font-black text-gray-900 border-t-2 border-brand/20 pt-4 mt-4">
                    <span>Total</span>
                    <span class="text-brand"><%= locals.currency || '$' %><%= (total - (locals.discount || 0)).toFixed(2) %></span>
                </div>
            </div>
        </div>

        <% if (locals.signature || locals.show_signature) { %>
        <!-- Signature Line -->
        <div class="px-12 py-10 flex justify-between items-end">
            <div class="w-64 text-center">
                <% if (locals.signature) { %>
                    <img src="<%= locals.signature %>" alt="Signature" class="max-h-12 mx-auto mb-2" />
                <% } %>
                <div class="border-b-2 border-gray-300 mb-2 <%= locals.signature ? '' : 'mt-8' %>"></div>
                <p class="text-sm text-gray-500 font-medium">Authorized Signature</p>
            </div>
            <div class="w-48 text-center">
                <p class="mb-2 text-gray-800 font-medium"><%= locals.signature_date || locals.date || new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
                <div class="border-b-2 border-gray-300 mb-2 <%= locals.signature ? '' : 'mt-8' %>"></div>
                <p class="text-sm text-gray-500 font-medium">Date</p>
            </div>
        </div>
        <% } %>

        <!-- Footer -->
        <div class="p-12 border-t border-gray-100 text-center">
            <p class="font-bold text-gray-800 mb-2">Thank you for your business!</p>
            <% if (locals.notes) { %>
            <p class="text-gray-500 text-sm max-w-2xl mx-auto"><%= locals.notes %></p>
            <% } %>
        </div>
    </div>
</body>
</html>