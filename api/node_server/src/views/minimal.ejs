<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - <%= project_name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Roboto', sans-serif; }
        .print-exact { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        @media print {
            body { background-color: white; padding: 0; }
            .print-hide { display: none; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '<%= locals.theme_color || "#3b82f6" %>'
                    }
                }
            }
        }
    </script>
</head>
<%
  function formatMoney(amount) {
    return Number(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>
<body class="bg-gray-100 p-8 flex justify-center print:p-0">
    <div class="bg-white w-full max-w-4xl p-16 print:p-0">
        
        <!-- Header -->
        <div class="flex justify-between items-start mb-24">
            <div class="space-y-6">
                <% if (locals.company_logo) { %>
                    <img src="<%= company_logo %>" alt="Company Logo" class="h-16 object-contain">
                <% } %>
                <% if (locals.company_name) { %>
                    <h2 class="text-2xl font-light text-gray-900 tracking-tight"><%= locals.company_name %></h2>
                <% } %>
                <div class="text-gray-400 text-sm leading-relaxed font-light">
                    <% if (locals.company_address) { %>
                        <p class="whitespace-pre-line"><%= locals.company_address %></p>
                    <% } %>
                    <% if (locals.company_email) { %>
                        <p><%= locals.company_email %></p>
                    <% } %>
                    <% if (locals.company_phone) { %>
                        <p><%= locals.company_phone %></p>
                    <% } %>
                </div>
            </div>
            <div class="text-right">
                <h1 class="text-3xl font-light text-gray-900 tracking-widest uppercase mb-8">Invoice</h1>
                <div class="text-gray-500 text-sm space-y-3 font-light">
                    <p><span class="font-medium text-gray-900 mr-4">No.</span> <%= locals.invoice_number || 'INV-0001' %></p>
                </div>
            </div>
        </div>

        <!-- Billing Info -->
        <div class="flex justify-between items-start mb-16">
            <div>
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Billed To</h3>
                <p class="font-medium text-gray-900 text-lg"><%= locals.client_name || 'Client Name' %></p>
                <p class="text-gray-500 text-sm mt-2 max-w-xs leading-relaxed whitespace-pre-line font-light">
                    <%= locals.client_address || 'Client Address\nCity, State Zip' %>
                </p>
                <% if (locals.client_email) { %>
                    <p class="text-gray-500 text-sm mt-1 font-light"><%= client_email %></p>
                <% } %>
            </div>
            <div class="text-right">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Project</h3>
                <p class="font-medium text-gray-900 text-lg max-w-sm"><%= project_name %></p>
            </div>
        </div>

        <!-- Items Table -->
        <div class="mb-16">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-gray-400 border-b border-gray-100 print:break-inside-avoid">
                        <th class="py-4 font-normal text-xs uppercase tracking-widest w-1/2">Description</th>
                        <th class="py-4 font-normal text-xs uppercase tracking-widest text-center">Qty</th>
                        <th class="py-4 font-normal text-xs uppercase tracking-widest text-right">Rate</th>
                        <th class="py-4 font-normal text-xs uppercase tracking-widest text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700 text-sm font-light">
                    <% line_items.forEach(function(item) { %>
                    <tr class="border-b border-gray-50 print:break-inside-avoid">
                        <td class="py-6">
                            <p class="text-gray-900 text-base"><%= item.description %></p>
                            <% if (item.discount_percentage) { %>
                            <p class="text-sm text-red-500 mt-1 font-light">Discount: <%= item.discount_percentage %>% (-<%= locals.currency || '$' %><%= formatMoney(item.discount || 0) %>)</p>
                            <% } else if (item.discount) { %>
                            <p class="text-sm text-red-500 mt-1 font-light">Discount: -<%= locals.currency || '$' %><%= formatMoney(item.discount) %></p>
                            <% } %>
                        </td>
                        <td class="py-6 text-center"><%= item.quantity %></td>
                        <td class="py-6 text-right text-gray-500"><%= locals.currency || '$' %><%= formatMoney(item.unit_price) %></td>
                        <td class="py-6 text-right font-medium text-gray-900"><%= locals.currency || '$' %><%= formatMoney((item.quantity * item.unit_price) - (item.discount || 0)) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <!-- Summary -->
        <div class="flex justify-between mb-24">
            <% if (locals.terms) { %>
            <div class="w-full max-w-md pr-8">
                <h3 class="text-xs text-gray-400 uppercase tracking-widest font-bold mb-3">Terms & Conditions</h3>
                <p class="text-sm text-gray-500 font-light whitespace-pre-line"><%= locals.terms %></p>
            </div>
            <% } %>
            <div class="w-full max-w-sm space-y-4 <% if (!locals.terms) { %>ml-auto<% } %>">
                <div class="flex justify-between text-gray-500 text-base font-light">
                    <span>Subtotal</span>
                    <span class="text-gray-900"><%= locals.currency || '$' %><%= formatMoney(subtotal) %></span>
                </div>
                <% if (locals.discount) { %>
                <div class="flex justify-between text-gray-500 text-base font-light">
                    <span>Discount</span>
                    <span class="text-brand">-<%= locals.currency || '$' %><%= formatMoney(Number(discount)) %></span>
                </div>
                <% } %>
                <div class="flex justify-between text-gray-500 text-base font-light">
                    <span>Taxes</span>
                    <span class="text-gray-900"><%= locals.currency || '$' %><%= formatMoney(taxes) %></span>
                </div>
                <div class="flex justify-between text-2xl font-light text-gray-900 pt-6 mt-6 border-t border-gray-100">
                    <span>Total</span>
                    <span class="font-medium"><%= locals.currency || '$' %><%= formatMoney((total - (locals.discount || 0))) %></span>
                </div>
            </div>
        </div>

        <% if (locals.signature || locals.show_signature) { %>
        <!-- Signature Line -->
        <div class="flex justify-between items-end mb-16">
            <div class="w-64 text-center">
                <% if (locals.signature) { %>
                    <img src="<%= locals.signature %>" alt="Signature" class="max-h-12 mx-auto mb-3" />
                <% } %>
                <div class="border-b border-gray-300 mb-3 <%= locals.signature ? '' : 'mt-8' %>"></div>
                <p class="text-xs text-gray-400 uppercase tracking-widest font-bold">Authorized Signature</p>
            </div>
            <div class="w-48 text-center">
                <p class="mb-3 text-gray-900 font-medium"><%= locals.signature_date || locals.date || new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
                <div class="border-b border-gray-300 mb-3 <%= locals.signature ? '' : 'mt-8' %>"></div>
                <p class="text-xs text-gray-400 uppercase tracking-widest font-bold">Date</p>
            </div>
        </div>
        <% } %>

        <!-- Footer -->
        <div class="text-center mt-12">
            <p class="text-gray-900 font-medium mb-2">Thank you for your business!</p>
            <% if (locals.notes) { %>
            <p class="text-gray-400 text-sm font-light max-w-2xl mx-auto"><%= locals.notes %></p>
            <% } %>
        </div>
    </div>
</body>
</html>