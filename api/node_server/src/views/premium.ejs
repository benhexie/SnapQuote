<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - <%= project_name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .print-exact { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        @media print {
            body { background-color: white; padding: 0; }
            .print-hide { display: none; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '<%= locals.theme_color || "#7C3AED" %>', // Indigo default
                        brandLight: '<%= locals.theme_color_light || "#EDE9FE" %>',
                        dark: '#18181B',
                        accent: '#F4F4F5'
                    }
                }
            }
        }
    </script>
</head>
<%
  function formatMoney(amount) {
    return Number(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>
<body class="bg-gray-100 p-8 flex justify-center print:p-0">
    <div class="bg-white w-full max-w-4xl shadow-2xl rounded-3xl overflow-hidden print:shadow-none print:rounded-none relative">
        
        <!-- Header -->
        <div class="p-12 pb-8 bg-dark text-white print-exact rounded-b-[3rem] relative z-10 shadow-lg">
            <div class="flex justify-between items-center mb-8">
                <div class="flex items-center gap-4">
                    <% if (locals.company_logo) { %>
                        <img src="<%= company_logo %>" alt="Company Logo" class="h-16 bg-white p-2 rounded-xl object-contain">
                    <% } %>
                    <div>
                        <h2 class="text-3xl font-extrabold tracking-tight text-white"><%= locals.company_name || 'Your Company Name' %></h2>
                        <div class="flex gap-4 text-gray-400 text-sm mt-1">
                            <p><%= locals.company_email || 'hello@yourcompany.com' %></p>
                            <p>•</p>
                            <p><%= locals.company_phone || '(555) 123-4567' %></p>
                        </div>
                    </div>
                </div>
                <div class="text-right">
                    <h1 class="text-6xl font-black text-brand tracking-tight mb-2">INVOICE</h1>
                    <div class="inline-flex items-center bg-white/10 px-4 py-2 rounded-full text-white/90">
                        <span class="font-bold mr-2 text-brandLight">NO.</span> 
                        <span><%= locals.invoice_number || 'INV-0001' %></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="px-12 py-8 -mt-8 pt-16 bg-accent print-exact relative z-0">
            <div class="flex justify-between">
                <div class="bg-white p-6 rounded-2xl shadow-sm w-[48%] print-exact border border-gray-100">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Invoice To</h3>
                    <p class="text-xl font-bold text-dark mb-1"><%= locals.client_name || 'Client Name' %></p>
                    <p class="text-gray-500 text-sm leading-relaxed whitespace-pre-line mb-2">
                        <%= locals.client_address || 'Client Address\nCity, State Zip' %>
                    </p>
                    <% if (locals.client_email) { %>
                        <p class="text-brand font-medium text-sm"><%= client_email %></p>
                    <% } %>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm w-[48%] print-exact border border-gray-100 flex flex-col justify-center">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Project Name</h3>
                    <p class="text-2xl font-bold text-dark mb-4"><%= project_name %></p>
                    <div class="flex justify-between border-t border-gray-100 pt-3">
                        <div>
                            <p class="text-xs text-gray-400 uppercase font-bold mb-1">Issue Date</p>
                            <p class="text-sm font-semibold text-dark"><%= locals.date || new Date().toLocaleDateString() %></p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-gray-400 uppercase font-bold mb-1">Amount Due</p>
                            <p class="text-sm font-bold text-brand"><%= locals.currency || '$' %><%= formatMoney((total - (locals.discount || 0) + ((total - (locals.discount || 0)) * (locals.tax_rate || 0)/100))) %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <div class="p-12">
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden print-exact">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50 print-exact border-b border-gray-200">
                        <tr class="text-dark">
                            <th class="py-4 px-6 font-bold uppercase text-xs tracking-widest w-1/2">Description</th>
                            <th class="py-4 px-6 font-bold uppercase text-xs tracking-widest text-center">Qty</th>
                            <th class="py-4 px-6 font-bold uppercase text-xs tracking-widest text-right">Rate</th>
                            <th class="py-4 px-6 font-bold uppercase text-xs tracking-widest text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 text-sm">
                        <% line_items.forEach(function(item, index) { %>
                        <tr class="<%= index !== line_items.length - 1 ? 'border-b border-gray-100' : '' %> group hover:bg-gray-50 transition-colors">
                            <td class="py-5 px-6">
                                <p class="font-semibold text-dark text-base"><%= item.description %></p>
                            </td>
                            <td class="py-5 px-6 text-center font-medium"><%= item.quantity %></td>
                            <td class="py-5 px-6 text-right"><%= locals.currency || '$' %><%= formatMoney(item.unit_price) %></td>
                            <td class="py-5 px-6 text-right font-bold text-dark"><%= locals.currency || '$' %><%= formatMoney((item.quantity * item.unit_price)) %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Summary & Footer -->
            <div class="mt-8 flex justify-between items-start">
                <div class="w-1/2 pr-8">
                    <% if (locals.show_signature) { %>
                    <div class="mt-12 bg-gray-50 p-6 rounded-2xl border border-gray-100 print-exact inline-block">
                        <div class="border-b-2 border-gray-300 h-12 w-48 mb-3"></div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest text-center">Authorized Signature</p>
                    </div>
                    <% } %>
                </div>
                
                <div class="w-1/2">
                    <div class="bg-dark text-white rounded-2xl p-6 shadow-lg print-exact relative overflow-hidden">
                        <!-- Decorative circle -->
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-white opacity-5 rounded-full blur-xl"></div>
                        
                        <div class="space-y-4 text-sm text-gray-300 mb-6 relative z-10">
                            <div class="flex justify-between">
                                <span class="font-medium">Subtotal</span>
                                <span class="text-white"><%= locals.currency || '$' %><%= formatMoney(total) %></span>
                            </div>
                            <% if (locals.discount) { %>
                            <div class="flex justify-between text-brandLight">
                                <span class="font-medium">Discount</span>
                                <span>-<%= locals.currency || '$' %><%= formatMoney(locals.discount) %></span>
                            </div>
                            <% } %>
                            <% if (locals.tax_rate) { %>
                            <div class="flex justify-between">
                                <span class="font-medium">Tax (<%= locals.tax_rate %>%)</span>
                                <span class="text-white"><%= locals.currency || '$' %><%= formatMoney(((total - (locals.discount || 0)) * (locals.tax_rate/100))) %></span>
                            </div>
                            <% } %>
                        </div>
                        <div class="flex justify-between pt-6 border-t border-gray-700 items-center relative z-10">
                            <span class="text-sm font-bold text-gray-300 uppercase tracking-widest">Total Due</span>
                            <span class="text-4xl font-black text-brandLight"><%= locals.currency || '$' %><%= formatMoney((total - (locals.discount || 0) + ((total - (locals.discount || 0)) * (locals.tax_rate || 0)/100))) %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</body>
</html>