<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - <%= project_name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Space Grotesk', sans-serif; }
        .print-exact { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        @media print {
            body { background-color: white; padding: 0; }
            .print-hide { display: none; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '<%= locals.theme_color || "#FF3366" %>', // Vibrant pink/red default
                        brandLight: '<%= locals.theme_color_light || "#FFF0F5" %>',
                        dark: '#0F172A'
                    }
                }
            }
        }
    </script>
</head>
<%
  function formatMoney(amount) {
    return Number(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>
<body class="bg-gray-100 p-8 flex justify-center print:p-0">
    <div class="bg-white w-full max-w-4xl shadow-2xl overflow-hidden print:shadow-none print:rounded-none relative">
        
        <!-- Header -->
        <div class="flex">
            <!-- Left Side Branding -->
            <div class="w-1/3 bg-brand print-exact text-white p-12 flex flex-col justify-between">
                <div>
                    <% if (locals.company_logo) { %>
                        <img src="<%= company_logo %>" alt="Company Logo" class="h-20 object-contain mb-8 filter invert brightness-0">
                    <% } else { %>
                        <h2 class="text-3xl font-bold tracking-tighter mb-8"><%= locals.company_name || 'Your Company Name' %></h2>
                    <% } %>
                    <div class="text-white/80 text-sm space-y-2">
                        <p><%= locals.company_address || '123 Business Road, Suite 100\nCity, State 12345' %></p>
                        <p><%= locals.company_email || 'hello@yourcompany.com' %></p>
                        <p><%= locals.company_phone || '(555) 123-4567' %></p>
                    </div>
                </div>
                <div class="mt-24">
                    <h1 class="text-5xl font-black tracking-tighter uppercase mb-4">Invoice</h1>
                    <div class="space-y-1 text-white/90 font-medium">
                        <p>No. <%= locals.invoice_number || 'INV-0001' %></p>
                        <p><%= locals.date || new Date().toLocaleDateString() %></p>
                    </div>
                </div>
            </div>

            <!-- Right Side Details -->
            <div class="w-2/3 p-12 flex flex-col">
                <div class="flex justify-between items-start mb-16">
                    <div class="w-full">
                        <h3 class="text-xs font-bold text-brand uppercase tracking-widest mb-2">Billed To</h3>
                        <p class="text-2xl font-bold text-dark mb-2"><%= locals.client_name || 'Client Name' %></p>
                        <p class="text-gray-500 text-sm leading-relaxed whitespace-pre-line">
                            <%= locals.client_address || 'Client Address\nCity, State Zip' %>
                        </p>
                        <% if (locals.client_email) { %>
                            <p class="text-gray-500 text-sm mt-1"><%= client_email %></p>
                        <% } %>
                    </div>
                    <div class="w-full pl-8">
                        <h3 class="text-xs font-bold text-brand uppercase tracking-widest mb-2">Project</h3>
                        <p class="text-2xl font-bold text-dark mb-2"><%= project_name %></p>
                    </div>
                </div>

                <!-- Items Table -->
                <div class="mb-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b-2 border-dark text-dark">
                                <th class="py-3 px-2 font-bold uppercase text-xs tracking-widest w-1/2">Description</th>
                                <th class="py-3 px-2 font-bold uppercase text-xs tracking-widest text-center">Qty</th>
                                <th class="py-3 px-2 font-bold uppercase text-xs tracking-widest text-right">Price</th>
                                <th class="py-3 px-2 font-bold uppercase text-xs tracking-widest text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="text-gray-600 text-sm">
                            <% line_items.forEach(function(item) { %>
                            <tr class="border-b border-gray-100 group hover:bg-gray-50 transition-colors">
                                <td class="py-4 px-2">
                                    <p class="font-medium text-dark text-base"><%= item.description %></p>
                                </td>
                                <td class="py-4 px-2 text-center font-medium"><%= item.quantity %></td>
                                <td class="py-4 px-2 text-right"><%= locals.currency || '$' %><%= formatMoney(item.unit_price) %></td>
                                <td class="py-4 px-2 text-right font-bold text-dark"><%= locals.currency || '$' %><%= formatMoney((item.quantity * item.unit_price)) %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Summary -->
                <div class="mt-12 bg-gray-50 p-8 rounded-2xl print-exact">
                    <div class="space-y-3 text-sm text-gray-600 mb-6">
                        <div class="flex justify-between">
                            <span class="font-medium">Subtotal</span>
                            <span><%= locals.currency || '$' %><%= formatMoney(total) %></span>
                        </div>
                        <% if (locals.discount) { %>
                        <div class="flex justify-between text-brand">
                            <span class="font-medium">Discount</span>
                            <span>-<%= locals.currency || '$' %><%= formatMoney(locals.discount) %></span>
                        </div>
                        <% } %>
                        <% if (locals.tax_rate) { %>
                        <div class="flex justify-between">
                            <span class="font-medium">Tax (<%= locals.tax_rate %>%)</span>
                            <span><%= locals.currency || '$' %><%= formatMoney(((total - (locals.discount || 0)) * (locals.tax_rate/100))) %></span>
                        </div>
                        <% } %>
                    </div>
                    <div class="flex justify-between pt-6 border-t-2 border-dark items-center">
                        <span class="text-xl font-bold text-dark uppercase tracking-widest">Total Due</span>
                        <span class="text-4xl font-black text-brand"><%= locals.currency || '$' %><%= formatMoney((total - (locals.discount || 0) + ((total - (locals.discount || 0)) * (locals.tax_rate || 0)/100))) %></span>
                    </div>
                </div>

                <!-- Footer -->
                <% if (locals.show_signature) { %>
                <div class="mt-12">
                    <div class="border-b-2 border-gray-200 h-16 w-48 mb-2"></div>
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Signature</p>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>