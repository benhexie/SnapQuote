<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - <%= project_name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Lato', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .print-exact { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        @media print {
            body { background-color: white; padding: 0; }
            .print-hide { display: none; }
            .bg-gold { background-color: #D4AF37 !important; }
            .text-gold { color: #D4AF37 !important; }
            .border-gold { border-color: #D4AF37 !important; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '<%= locals.theme_color || "#D4AF37" %>', // Default gold
                        brandLight: '<%= locals.theme_color_light || "#F9F6EE" %>',
                        dark: '#1A1A1A'
                    }
                }
            }
        }
    </script>
</head>
<%
  function formatMoney(amount) {
    return Number(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>
<body class="bg-gray-100 p-8 flex justify-center print:p-0">
    <div class="bg-white w-full max-w-4xl shadow-2xl overflow-hidden print:shadow-none print:rounded-none relative">
        
        <!-- Top decorative bar -->
        <div class="h-3 w-full bg-brand print-exact"></div>

        <div class="p-16">
            <!-- Header -->
            <div class="flex justify-between items-start border-b border-gray-200 pb-12 mb-12">
                <div class="w-1/2">
                    <% if (locals.company_logo) { %>
                        <img src="<%= company_logo %>" alt="Company Logo" class="h-24 object-contain mb-6">
                    <% } %>
                    <% if (locals.company_name) { %>
                        <h2 class="text-4xl font-serif font-bold text-dark mb-6"><%= locals.company_name %></h2>
                    <% } %>
                    <div class="text-gray-600 text-sm leading-loose">
                        <% if (locals.company_address) { %>
                        <p><%= locals.company_address %></p>
                        <% } %>
                        <% if (locals.company_email) { %>
                        <p><%= locals.company_email %></p>
                        <% } %>
                        <% if (locals.company_phone) { %>
                        <p><%= locals.company_phone %></p>
                        <% } %>
                    </div>
                </div>
                <div class="w-1/2 text-right">
                    <h1 class="text-6xl font-serif text-brand tracking-widest uppercase mb-6">Invoice</h1>
                    <div class="text-gray-600 space-y-2">
                        <p class="text-lg"><span class="font-semibold text-dark mr-3">Invoice No.</span> <%= locals.invoice_number || 'INV-0001' %></p>
                        <p class="text-lg"><span class="font-semibold text-dark mr-3">Date</span> <%= locals.date || new Date().toLocaleDateString() %></p>
                    </div>
                </div>
            </div>

            <!-- Billing Info -->
            <div class="flex justify-between items-start mb-16">
                <div class="w-1/2 pr-8">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4 border-b border-gray-200 pb-2">Billed To</h3>
                    <p class="font-serif text-2xl text-dark mb-2"><%= locals.client_name || 'Client Name' %></p>
                    <p class="text-gray-600 text-sm leading-loose whitespace-pre-line">
                        <%= locals.client_address || 'Client Address\nCity, State Zip' %>
                    </p>
                    <% if (locals.client_email) { %>
                        <p class="text-gray-600 text-sm mt-1"><%= client_email %></p>
                    <% } %>
                </div>
                <div class="w-1/2 pl-8">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4 border-b border-gray-200 pb-2">Project Description</h3>
                    <p class="font-serif text-2xl text-dark mb-2"><%= project_name %></p>
                    <p class="text-gray-600 text-sm leading-loose">Thank you for your business. It's a pleasure working with you on this project.</p>
                </div>
            </div>

            <!-- Items Table -->
            <div class="mb-16">
                <table class="w-full text-left border-collapse">
                    <thead class="print:break-inside-avoid">
                        <tr class="border-b-2 border-dark text-dark">
                            <th class="py-4 px-2 font-bold uppercase text-xs tracking-widest w-1/2">Item Description</th>
                            <th class="py-4 px-2 font-bold uppercase text-xs tracking-widest text-center">Qty</th>
                            <th class="py-4 px-2 font-bold uppercase text-xs tracking-widest text-right">Rate</th>
                            <th class="py-4 px-2 font-bold uppercase text-xs tracking-widest text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 text-sm">
                        <% line_items.forEach(function(item) { %>
                        <tr class="border-b border-gray-100 print:break-inside-avoid">
                            <td class="py-6 px-2">
                                <p class="font-serif text-lg text-dark"><%= item.description %></p>
                                <% if (item.discount_percentage) { %>
                                <p class="text-sm text-red-600 mt-1 font-sans">Discount: <%= item.discount_percentage %>% (-<%= locals.currency || '$' %><%= formatMoney(item.discount || 0) %>)</p>
                                <% } else if (item.discount) { %>
                                <p class="text-sm text-red-600 mt-1 font-sans">Discount: -<%= locals.currency || '$' %><%= formatMoney(item.discount) %></p>
                                <% } %>
                            </td>
                            <td class="py-6 px-2 text-center text-base"><%= item.quantity %></td>
                            <td class="py-6 px-2 text-right text-base"><%= locals.currency || '$' %><%= formatMoney(item.unit_price) %></td>
                            <td class="py-6 px-2 text-right font-bold text-dark text-base"><%= locals.currency || '$' %><%= formatMoney((item.quantity * item.unit_price) - (item.discount || 0)) %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Summary -->
            <div class="flex justify-end">
                <div class="w-1/2">
                    <div class="space-y-4 text-sm text-gray-600">
                        <div class="flex justify-between py-2 border-b border-gray-100">
                            <span class="font-medium">Subtotal</span>
                            <span><%= locals.currency || '$' %><%= formatMoney(total) %></span>
                        </div>
                        <% if (locals.discount) { %>
                        <div class="flex justify-between py-2 border-b border-gray-100 text-brand">
                            <span class="font-medium">Discount</span>
                            <span>-<%= locals.currency || '$' %><%= formatMoney(locals.discount) %></span>
                        </div>
                        <% } %>
                        <% if (locals.tax_rate) { %>
                        <div class="flex justify-between py-2 border-b border-gray-100">
                            <span class="font-medium">Tax (<%= locals.tax_rate %>%)</span>
                            <span><%= locals.currency || '$' %><%= formatMoney((total - (locals.discount || 0)) * (locals.tax_rate/100)) %></span>
                        </div>
                        <% } %>
                        <div class="flex justify-between items-center py-6 mt-4 border-t-2 border-dark">
                            <span class="font-serif text-2xl font-bold text-dark uppercase tracking-widest">Total Due</span>
                            <span class="font-serif text-3xl font-bold text-brand"><%= locals.currency || '$' %><%= formatMoney(total - (locals.discount || 0) + ((total - (locals.discount || 0)) * (locals.tax_rate || 0)/100)) %></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <% if (locals.signature || locals.show_signature) { %>
            <div class="mt-24 flex justify-between items-end">
                <div class="w-1/3">
                    <% if (locals.signature) { %>
                        <img src="<%= locals.signature %>" alt="Signature" class="max-h-16 mb-2" />
                    <% } %>
                    <div class="border-b border-gray-400 h-2 mb-2 <%= locals.signature ? '' : 'mt-14' %>"></div>
                    <p class="text-xs text-gray-500 text-center uppercase tracking-widest">Authorized Signature</p>
                    <p class="text-sm font-medium text-gray-700 text-center mt-1"><%= locals.signature_date || locals.date || new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
                </div>
                <div class="w-1/3 text-right">
                    <p class="font-serif text-brand italic">Thank You!</p>
                </div>
            </div>
            <% } %>
        </div>
        
        <!-- Bottom decorative bar -->
        <div class="h-1 w-full bg-dark print-exact mt-12"></div>
    </div>
</body>
</html>